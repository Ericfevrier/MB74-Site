# ------------------------------------------------------------------
#  Directus — configuration o2switch (cms.motorboat74.com)
#  Copier en .env dans le dossier de l'app (~/cms.motorboat74.com/.env)
#  Générer KEY et SECRET :  openssl rand -hex 32   (une valeur différente chacun)
# ------------------------------------------------------------------

# Réseau — Passenger fournit PORT automatiquement, NE PAS le fixer ici.
HOST="0.0.0.0"
PUBLIC_URL="https://cms.motorboat74.com"

# Secrets (OBLIGATOIRES — remplacer par deux valeurs aléatoires distinctes)
KEY="REMPLACER_PAR_openssl_rand_hex_32"
SECRET="REMPLACER_PAR_openssl_rand_hex_32"

# Base de données MariaDB (cPanel > MySQL Databases)
DB_CLIENT="mysql"
DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="motorbo_directus"
DB_USER="motorbo_directus"
DB_PASSWORD="MOT_DE_PASSE_DB"

# Compte admin initial (créé par `npx directus bootstrap`)
ADMIN_EMAIL="admin@motorboat74.com"
ADMIN_PASSWORD="MOT_DE_PASSE_ADMIN_FORT"

# CORS — autoriser le site (prod + staging) à appeler l'API
CORS_ENABLED="true"
CORS_ORIGIN="https://motorboat74.com,https://www.motorboat74.com,https://staging.motorboat74.com"

# Confort / sobriété sur hébergement mutualisé
WEBSOCKETS_ENABLED="false"
TELEMETRY="false"
LOG_LEVEL="info"

# Stockage des médias : disque local par défaut (dossier ./uploads), rien à configurer.
# Cache (optionnel) : laissé désactivé ; activable plus tard si besoin.
