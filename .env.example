# ------------------------------------------------------------------
#  Motor Boat 74 — variables d'environnement
#  Copier ce fichier en .env.local (dev) ou .env (prod o2switch)
# ------------------------------------------------------------------

# Clé Google Maps Platform (optionnelle — la carte a un fallback sans clé)
GOOGLE_MAPS_PLATFORM_KEY=""

# ------------------------------------------------------------------
#  Base de données MariaDB / MySQL (admin + données live)
#  Sur o2switch : créer la base via cPanel « Bases de données MySQL »
#  (moteur MariaDB). host = localhost ; base/utilisateur préfixés (sc1yabi9373_…).
#  Sans ces variables : le site fonctionne sur les données statiques (repli)
#  et les formulaires sont seulement envoyés par e-mail (non persistés).
# ------------------------------------------------------------------
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="sc1yabi9373_mb74"
DB_USER="sc1yabi9373_mb74"
DB_PASSWORD="MOT_DE_PASSE_BASE"

# ------------------------------------------------------------------
#  Compte ADMIN (/admin) — compte unique
#  Deux options pour le mot de passe (l'une OU l'autre) :
#   - ADMIN_PASSWORD       : mot de passe EN CLAIR. ✅ Recommandé sur cPanel/Passenger
#                            (évite le souci du `$` des hash bcrypt mal interprété).
#   - ADMIN_PASSWORD_HASH  : hash bcrypt → `node scripts/hash-password.mjs 'MonMdp'`
#                            (à éviter si le panel interprète le `$`).
#  SESSION_SECRET          : clé de signature du cookie de session (longue chaîne aléatoire).
# ------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="MonMotDePasseAdmin"
# ADMIN_PASSWORD_HASH=""
SESSION_SECRET=""

# ------------------------------------------------------------------
#  Envoi des e-mails (formulaires contact + hivernage)
#  Renseigner ces variables pour activer l'envoi réel.
#  Sans elles, les formulaires sont acceptés mais simplement journalisés.
#  Sur o2switch : SMTP du domaine (cPanel > Comptes de messagerie).
# ------------------------------------------------------------------
SMTP_HOST="mail.motorboat74.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="contact@motorboat74.com"
SMTP_PASS="MOT_DE_PASSE_DU_COMPTE_MAIL"

# Destinataire des demandes et adresse d'expédition
MAIL_TO="contact@motorboat74.com"
MAIL_FROM="no-reply@motorboat74.com"

# Port du serveur (injecté automatiquement par o2switch/Passenger en prod)
# PORT="3000"

# ------------------------------------------------------------------
#  Protection PRÉPRODUCTION (staging.motorboat74.com)
#  Le serveur applique « noindex + Basic Auth » UNIQUEMENT quand le hostname
#  correspond à STAGING_HOST. En production (motorboat74.com), aucune restriction.
#  ⚠️ Tant que STAGING_USER/STAGING_PASS ne sont pas renseignés, la préprod
#  renvoie 503 (fermée par défaut). À renseigner dans le .env d'o2switch.
# ------------------------------------------------------------------
STAGING_HOST="staging.motorboat74.com"
STAGING_USER="mb74"
STAGING_PASS="CHOISIR_UN_MOT_DE_PASSE"
# Forcer la protection sur CE déploiement (recommandé sur la préprod o2switch,
# fiable même si le Host diffère). NE PAS définir en production.
STAGING_PROTECT="1"
